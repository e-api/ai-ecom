APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ASSET_URL=http://localhost
FILAMENT_ASSETS_PATH=http://localhost

PHP_VERSION=
POSTGRES_VERSION=
POSTGRES_DB=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
PHP_FPM_PORT=9000
PROJECT_PATH=/www/wwwroot/default/project-name

# Resource Limits
POSTGRES_CPUS=1
POSTGRES_MEMORY_LIMIT=512MB
PHP_CPUS=1
PHP_MEMORY_LIMIT=512MB
 
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# DB_CONNECTION=pgsql
# DB_HOST="${APP_NAME}-postgres" # Hostname must combined APP_NAME-postgres from Docker Compose
# DB_PORT=5432
# DB_DATABASE=
# DB_USERNAME=postgres
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local # Change to s3 if using AWS S3 for storage
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Floci port
FLOCI_PORT=4566

# S3 / Floci Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT="${APP_URL}/s3"
AWS_USE_PATH_STYLE_ENDPOINT=false # Set to true if using local S3-compatible storage like Floci, false for AWS S3

VITE_APP_NAME="${APP_NAME}"
